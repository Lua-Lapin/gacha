{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "gacha-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--port", "5173", "--strictPort"],
      "port": 5173,
      "autoPort": false
    },
    {
      "name": "gacha-server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "server"],
      "port": 3001
    },
    {
      "name": "gallery",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "gallery"],
      "port": 5175
    },
    {
      "name": "gallery-dist",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "-d", "gallery/dist", "4178"],
      "port": 4178
    }
  ]
}
